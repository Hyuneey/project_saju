{
  "name": "project-saju",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build:solar-terms": "node scripts/solar-terms.mjs generate",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:solar-terms-source": "node scripts/check-solar-terms-source.mjs",
    "dev": "corepack pnpm --filter web dev",
    "import:solar-terms": "node scripts/solar-terms.mjs import",
    "test": "vitest run",
    "typecheck": "corepack pnpm -r typecheck",
    "validate:solar-terms": "node scripts/solar-terms.mjs validate",
    "verify": "corepack pnpm check:encoding && corepack pnpm validate:solar-terms && corepack pnpm check:solar-terms-source && corepack pnpm test && corepack pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "astronomy-engine": "^2.1.19",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
